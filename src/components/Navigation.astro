---
import personal from "../data/personal.json";

const links = [
  { no: "02", label: "Profile", href: "#about" },
  { no: "03", label: "Work", href: "#work" },
  { no: "04", label: "Experience", href: "#experience" },
  { no: "05", label: "Education", href: "#education" },
  { no: "06", label: "Contact", href: "#contact" },
];
---

<header id="site-nav" class="fixed inset-x-0 top-0 z-50 border-b border-rule">
  <div class="shell flex h-16 items-center justify-between">
    <a href="#top" class="group flex items-center gap-3" aria-label="Back to top">
      <span class="block h-2.5 w-2.5 bg-vermilion transition-transform duration-300 group-hover:rotate-45"
      ></span>
      <span class="mono-label"
        >Patel, Dhaval<span class="hidden sm:inline"> — Engineering Record</span></span
      >
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Primary">
      {
        links.map((link) => (
          <a href={link.href} class="nav-link mono-label">
            <sup class="mr-1 text-vermilion">{link.no}</sup>
            {link.label}
          </a>
        ))
      }
    </nav>

    <button
      id="menu-btn"
      class="menu-btn md:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Toggle menu"
    >
      <span class="menu-bar"></span>
      <span class="menu-bar"></span>
    </button>
  </div>
</header>

<div id="mobile-menu" class="mobile-menu" aria-hidden="true">
  <nav class="shell flex flex-col" aria-label="Mobile">
    {
      links.map((link, i) => (
        <a
          href={link.href}
          class="mobile-link border-t border-rule py-5"
          style={`--d: ${i * 60}ms`}
        >
          <span class="mono-label mr-4 text-vermilion">{link.no}</span>
          <span class="font-display text-4xl leading-none">{link.label}</span>
        </a>
      ))
    }
    <div class="mt-10 border-t border-rule pt-6">
      <p class="mono-label text-muted">Direct line</p>
      <a href={`mailto:${personal.email}`} class="mt-2 block font-mono text-sm">
        {personal.email}
      </a>
    </div>
  </nav>
</div>

<style>
  #site-nav {
    background: transparent;
    transition:
      background-color 0.35s ease,
      backdrop-filter 0.35s ease;
  }

  #site-nav.scrolled {
    background-color: color-mix(in srgb, var(--color-paper) 88%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .nav-link {
    position: relative;
    padding-block: 0.25rem;
    color: var(--color-ink);
  }

  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background: var(--color-vermilion);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.3s cubic-bezier(0.22, 0.65, 0.26, 1);
  }

  .nav-link:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .menu-btn {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 7px;
    width: 44px;
    height: 44px;
    align-items: center;
  }

  .menu-bar {
    display: block;
    width: 26px;
    height: 1.5px;
    background: var(--color-ink);
    transition: transform 0.3s ease;
  }

  :global(body.menu-open) .menu-bar:first-child {
    transform: translateY(4.25px) rotate(45deg);
  }

  :global(body.menu-open) .menu-bar:last-child {
    transform: translateY(-4.25px) rotate(-45deg);
  }

  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 45;
    background: var(--color-paper);
    padding-top: 6.5rem;
    transform: translateY(-102%);
    transition:
      transform 0.45s cubic-bezier(0.22, 0.65, 0.26, 1),
      visibility 0s linear 0.45s;
    visibility: hidden;
  }

  :global(body.menu-open) .mobile-menu {
    transform: none;
    visibility: visible;
    transition:
      transform 0.45s cubic-bezier(0.22, 0.65, 0.26, 1),
      visibility 0s;
  }

  .mobile-link {
    opacity: 0;
    transform: translateY(14px);
    transition:
      opacity 0.4s ease var(--d, 0ms),
      transform 0.4s ease var(--d, 0ms);
  }

  :global(body.menu-open) .mobile-link {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-menu,
    .mobile-link {
      transition: none;
    }
    .mobile-link {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  const header = document.getElementById("site-nav")!;
  const btn = document.getElementById("menu-btn")!;
  const menu = document.getElementById("mobile-menu")!;

  const setMenu = (open: boolean) => {
    document.body.classList.toggle("menu-open", open);
    btn.setAttribute("aria-expanded", String(open));
    menu.setAttribute("aria-hidden", String(!open));
  };

  btn.addEventListener("click", () =>
    setMenu(!document.body.classList.contains("menu-open"))
  );

  menu.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => setMenu(false))
  );

  const onScroll = () => header.classList.toggle("scrolled", window.scrollY > 24);
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });
</script>
