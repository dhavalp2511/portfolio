---
import experienceData from "../../data/experience.json";

const entries = experienceData.experience;
---

<section id="experience" class="section-pad relative">
  <div class="shell">
    <div class="fig-head reveal">
      <span class="fig-no">Fig. 04</span>
      <span class="fig-rule"></span>
      <span class="mono-label hidden text-muted sm:block">2018 — present · 4 postings</span>
    </div>

    <h2 class="display-head reveal mt-10" style="--d: 80ms">
      Service <em>record</em><span class="dot">.</span>
    </h2>

    <div class="mt-16">
      {
        entries.map((entry, i) => (
          <article class="reveal grid gap-6 border-t border-rule py-12 last:border-b lg:grid-cols-12 lg:gap-8">
            <div class="lg:col-span-3">
              <p class="mono-label text-vermilion">
                E-{String(entries.length - i).padStart(2, "0")}
              </p>
              <p class="mono-label mt-3">{entry.duration}</p>
              <p class="mono-label mt-2 text-muted">{entry.location}</p>
              <span class="stamp mt-4 py-1!">{entry.type}</span>
            </div>

            <div class="lg:col-span-8 lg:col-start-5">
              <h3 class="font-display text-3xl font-[440] leading-tight tracking-tight sm:text-4xl">
                {entry.company}
              </h3>
              <p class="mono-label mt-3 text-muted">{entry.position}</p>
              <p class="mt-5 max-w-2xl text-[0.95rem] leading-relaxed text-ink-soft">
                {entry.description}
              </p>

              <ul class="mt-7 max-w-2xl">
                {entry.achievements.map((achievement) => (
                  <li class="flex gap-4 border-t border-rule py-3 text-[0.9rem] leading-relaxed text-ink-soft last:border-b">
                    <span class="text-vermilion" aria-hidden="true">
                      →
                    </span>
                    {achievement}
                  </li>
                ))}
              </ul>

              <p class="mono-label mt-6 max-w-2xl normal-case! tracking-[0.06em]! text-muted">
                {entry.technologies.join(" · ")}
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
