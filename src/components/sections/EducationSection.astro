---
import educationData from "../../data/education.json";

const education = educationData.education[0];
const [gpa, gpaScale] = education.gpa.split("/");
---

<section id="education" class="section-pad relative">
  <div class="shell">
    <div class="fig-head reveal">
      <span class="fig-no">Fig. 05</span>
      <span class="fig-rule"></span>
      <span class="mono-label hidden text-muted sm:block">{education.duration}</span>
    </div>

    <h2 class="display-head reveal mt-10" style="--d: 80ms">
      Foundation<span class="dot">.</span>
    </h2>

    <div class="reveal mt-16 grid gap-10 border border-rule-strong p-8 sm:p-10 lg:grid-cols-12 lg:gap-8" style="--d: 120ms">
      <div class="lg:col-span-7">
        <h3 class="font-display text-2xl font-[440] leading-tight tracking-tight sm:text-3xl">
          {education.institution}
        </h3>
        <p class="mono-label mt-3 text-muted">
          {education.degree} · {education.duration} · {education.location}
        </p>
        <p class="mt-5 max-w-xl text-[0.95rem] leading-relaxed text-ink-soft">
          {education.description}
        </p>

        <h4 class="mono-label mt-8 text-muted">Relevant coursework</h4>
        <ul class="mt-3 flex max-w-xl flex-wrap gap-1.5">
          {
            education.relevantCourses.map((course) => (
              <li class="stamp px-2.5! py-1.5!">{course}</li>
            ))
          }
        </ul>
      </div>

      <div class="lg:col-span-4 lg:col-start-9">
        <p class="mono-label text-muted">Grade point average</p>
        <p class="mt-2 font-display leading-none">
          <span class="text-7xl font-[420] tracking-tight sm:text-8xl">{gpa}</span>
          <span class="mono-label ml-2 text-muted">/ {gpaScale}</span>
        </p>

        <h4 class="mono-label mt-10 text-muted">Also on record</h4>
        <ul class="mt-3">
          {
            education.achievements.map((achievement) => (
              <li class="flex gap-3 border-t border-rule py-3 text-[0.9rem] leading-relaxed text-ink-soft last:border-b">
                <span class="text-vermilion" aria-hidden="true">
                  →
                </span>
                {achievement}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>
