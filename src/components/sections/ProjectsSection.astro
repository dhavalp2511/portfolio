---
import projectsData from "../../data/projects.json";

const projects = projectsData.projects;

const platformsFor = (technologies: string[]) => {
  const t = technologies.join(" ").toLowerCase();
  const platforms: string[] = [];
  if (t.includes("react native") || t.includes("expo") || t.includes("android")) {
    platforms.push("Android");
  }
  if (t.includes("react native") || t.includes("expo")) {
    platforms.push("iOS");
  }
  if (t.includes("next.js") || t.includes("admin panel")) {
    platforms.push("Web");
  }
  return platforms;
};

const statusLabel = (status: string) =>
  status === "in-progress" ? "In progress" : "Shipped";
---

<section id="work" class="dark-zone section-pad relative">
  <div class="shell">
    <div class="fig-head reveal">
      <span class="fig-no">Fig. 03</span>
      <span class="fig-rule"></span>
      <span class="mono-label hidden text-muted sm:block">
        {projects.length} entries · 2019 — present
      </span>
    </div>

    <h2 class="display-head reveal mt-10" style="--d: 80ms">
      Selected <em>work</em><span class="dot">.</span>
    </h2>

    <div class="mt-16">
      {
        projects.map((project, i) => (
          <article class="project-row reveal group relative grid gap-6 border-t border-rule py-10 last:border-b lg:grid-cols-12 lg:gap-8">
            <div class="lg:col-span-1">
              <span class="project-index font-display italic">
                {String(i + 1).padStart(2, "0")}
              </span>
            </div>

            <div class="lg:col-span-7">
              <h3 class="font-display text-3xl font-[440] leading-tight tracking-tight sm:text-4xl">
                {project.liveUrl ? (
                  <a
                    href={project.liveUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="project-title-link"
                  >
                    {project.title}
                    <span class="project-arrow" aria-hidden="true">
                      ↗
                    </span>
                  </a>
                ) : (
                  project.title
                )}
              </h3>
              <p class="mt-4 max-w-2xl text-[0.95rem] leading-relaxed text-muted">
                {project.description}
              </p>
              <p class="mono-label mt-5 max-w-2xl normal-case! tracking-[0.06em]! text-muted">
                {project.technologies.join(" · ")}
              </p>
            </div>

            <div class="lg:col-span-4">
              <dl class="meta-table">
                <div class="meta-row">
                  <dt class="mono-label text-muted">Date</dt>
                  <dd class="mono-label">{project.date}</dd>
                </div>
                <div class="meta-row">
                  <dt class="mono-label text-muted">Status</dt>
                  <dd>
                    <span
                      class:list={[
                        "stamp py-1!",
                        project.status === "in-progress" &&
                          "border-ember! text-ember!",
                      ]}
                    >
                      {statusLabel(project.status)}
                    </span>
                  </dd>
                </div>
                <div class="meta-row">
                  <dt class="mono-label text-muted">Target</dt>
                  <dd class="flex flex-wrap justify-end gap-1.5">
                    {platformsFor(project.technologies).map((p) => (
                      <span class="stamp px-2! py-1!">{p}</span>
                    ))}
                  </dd>
                </div>
                {project.liveUrl && (
                  <div class="meta-row">
                    <dt class="mono-label text-muted">Link</dt>
                    <dd>
                      <a
                        href={project.liveUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="mono-label live-link"
                      >
                        View live ↗
                      </a>
                    </dd>
                  </div>
                )}
              </dl>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .project-index {
    font-size: 2.5rem;
    font-weight: 320;
    line-height: 1;
    color: rgb(242 238 227 / 0.35);
    transition: color 0.3s ease;
  }

  .project-row:hover .project-index {
    color: var(--color-ember);
  }

  .project-title-link {
    position: relative;
    transition: color 0.3s ease;
  }

  .project-title-link:hover {
    color: var(--color-ember);
  }

  .project-arrow {
    display: inline-block;
    margin-left: 0.35rem;
    font-size: 0.55em;
    vertical-align: super;
    opacity: 0.5;
    transition:
      transform 0.3s cubic-bezier(0.22, 0.65, 0.26, 1),
      opacity 0.3s ease;
  }

  .project-title-link:hover .project-arrow {
    transform: translate(4px, -4px);
    opacity: 1;
  }

  .meta-table {
    border: 1px solid var(--color-rule);
  }

  .meta-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.7rem 0.9rem;
  }

  .meta-row + .meta-row {
    border-top: 1px solid var(--color-rule);
  }

  .live-link {
    color: var(--color-ember);
    transition: opacity 0.25s ease;
  }

  .live-link:hover {
    opacity: 0.7;
  }
</style>
