---
import personal from "../../data/personal.json";

const year = new Date().getFullYear();

const socials = [
  ["GitHub", personal.social.github],
  ["LinkedIn", personal.social.linkedin],
  ["Twitter", personal.social.twitter],
  ["Instagram", personal.social.instagram],
].filter(([, url]) => Boolean(url)) as [string, string][];

const colophon = [
  "Designed & engineered by D. Patel",
  "Set in Fraunces, Archivo & IBM Plex Mono",
  "Built with Astro · Deployed on GitHub Pages",
];
---

<footer id="contact" class="dark-zone section-pad relative">
  <div class="shell">
    <div class="fig-head reveal">
      <span class="fig-no">Fig. 06</span>
      <span class="fig-rule"></span>
      <span class="mono-label hidden text-muted sm:block">Final sheet</span>
    </div>

    <h2 class="display-head reveal mt-12 max-w-4xl" style="--d: 80ms">
      Have something worth <em>building</em><span class="dot">?</span>
    </h2>

    <div class="reveal mt-12" style="--d: 160ms">
      <p class="mono-label text-muted">Open the correspondence</p>
      <a href={`mailto:${personal.email}`} class="email-link mt-3 inline-block font-display italic">
        {personal.email}
      </a>
      <p class="mono-label mt-6 text-muted">
        {personal.phone} · {personal.location}
      </p>
    </div>

    <div
      class="reveal mt-20 flex flex-wrap items-center gap-x-8 gap-y-3 border-t border-rule pt-6"
      style="--d: 100ms"
    >
      {
        socials.map(([label, url]) => (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="mono-label social-link"
          >
            {label} ↗
          </a>
        ))
      }
      <a href="#top" class="mono-label social-link sm:ml-auto">↑ Return to sheet 01</a>
    </div>

    <div class="reveal mt-12 grid border border-rule sm:grid-cols-4" style="--d: 140ms">
      {
        colophon.map((line) => (
          <p class="mono-label border-b border-rule px-4 py-3 text-muted sm:border-b-0 sm:border-r">
            {line}
          </p>
        ))
      }
      <p class="mono-label px-4 py-3 text-muted">© {year} · Rev 2026.06</p>
    </div>
  </div>
</footer>

<style>
  .email-link {
    font-size: clamp(1.5rem, 4.5vw, 3rem);
    font-weight: 420;
    letter-spacing: -0.01em;
    text-decoration: underline;
    text-decoration-color: var(--color-ember);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
    transition: color 0.3s ease;
    overflow-wrap: anywhere;
  }

  .email-link:hover {
    color: var(--color-ember);
  }

  .social-link {
    color: var(--color-paper);
    transition: color 0.25s ease;
  }

  .social-link:hover {
    color: var(--color-ember);
  }
</style>
