---
import about from "../../data/about.json";
import projectsData from "../../data/projects.json";

const skillGroups = [
  { code: "M", label: "Mobile", items: about.skills.mobile },
  { code: "F", label: "Frontend", items: about.skills.frontend },
  { code: "B", label: "Backend", items: about.skills.backend },
  { code: "T", label: "Tooling", items: about.skills.tools },
];

const stats = [
  { value: about.yearsOfExperience, caption: "Years in service" },
  { value: String(projectsData.projects.length), caption: "Products documented" },
  { value: "1M+", caption: "Cumulative installs" },
];
---

<section id="about" class="section-pad relative">
  <div class="shell">
    <div class="fig-head reveal">
      <span class="fig-no">Fig. 02</span>
      <span class="fig-rule"></span>
      <span class="mono-label hidden text-muted sm:block">Est. 2018 · Ahmedabad, IN</span>
    </div>

    <h2 class="display-head reveal mt-10" style="--d: 80ms">
      Profile<span class="dot">.</span>
    </h2>

    <div class="mt-14 grid gap-14 lg:grid-cols-12 lg:gap-8">
      <div class="lg:col-span-7">
        <p
          class="reveal max-w-2xl font-display text-2xl font-[380] leading-snug sm:text-[1.75rem]"
          style="--d: 120ms"
        >
          {about.description}
        </p>

        <div class="reveal mt-12" style="--d: 180ms">
          <h3 class="mono-label text-muted">Notes on record</h3>
          <ol class="mt-4">
            {
              about.achievements.map((item, i) => (
                <li class="flex gap-5 border-t border-rule py-4 last:border-b">
                  <span class="mono-label pt-0.5 text-vermilion">
                    N-{String(i + 1).padStart(2, "0")}
                  </span>
                  <span class="text-[0.95rem] leading-relaxed text-ink-soft">{item}</span>
                </li>
              ))
            }
          </ol>
        </div>
      </div>

      <div class="lg:col-span-5">
        <h3 class="reveal mono-label text-muted" style="--d: 160ms">
          Bill of materials
        </h3>
        <div class="mt-4">
          {
            skillGroups.map((group, gi) => (
              <div
                class="reveal border-t border-rule py-5 last:border-b"
                style={`--d: ${200 + gi * 70}ms`}
              >
                <div class="flex items-baseline gap-3">
                  <span class="mono-label text-vermilion">{group.code}</span>
                  <span class="font-display text-lg italic">{group.label}</span>
                </div>
                <ul class="mt-3 flex flex-wrap gap-1.5">
                  {group.items.map((item) => (
                    <li class="stamp px-2.5! py-1.5!">{item}</li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <dl class="reveal mt-20 grid border border-rule-strong sm:grid-cols-3" style="--d: 120ms">
      {
        stats.map((stat) => (
          <div class="border-b border-rule px-6 py-8 last:border-b-0 sm:border-b-0 sm:border-r sm:last:border-r-0">
            <dd class="font-display text-6xl font-[420] leading-none tracking-tight sm:text-7xl">
              {stat.value}
            </dd>
            <dt class="mono-label mt-4 text-muted">{stat.caption}</dt>
          </div>
        ))
      }
    </dl>
  </div>
</section>
